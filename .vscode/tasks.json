{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build",
			"type": "process",
			"command": "dotnet",
			"args": [ "build", "${workspaceFolder}/Quartz.Presentation/Quartz.Presentation.csproj" ],
			"group": "build",
			"problemMatcher": [ "$msCompile" ],
			"isBuildCommand": true,
			"presentation": {
				"reveal": "silent",
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			}
		},
		{
			"label": "Run",
			"type": "process",
			"command": "dotnet",
			"args": [ "run", "--project", "${workspaceFolder}/Quartz.Presentation/Quartz.Presentation.csproj" ],
			"group": "test",
			"problemMatcher": [ ]
		}
	]
}
